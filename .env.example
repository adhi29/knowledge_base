# ── Groq LLM  ─────────────────────────────────────────────────────────────────
# Free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Models (defaults shown — no need to change for the demo)
LLM_MODEL=llama-3.3-70b-versatile      # main generation model
ROUTER_MODEL=llama-3.1-8b-instant      # fast model for classify/rewrite

# ── Embeddings (local, no API key needed) ─────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ── Storage ───────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
SQLITE_DB_PATH=data/chatbot.db

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
BM25_WEIGHT=0.4
SEMANTIC_WEIGHT=0.6

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Enterprise Connectors (optional — leave blank to skip) ───────────────────
# Confluence (Atlassian Cloud)
CONFLUENCE_URL=https://yourorg.atlassian.net
CONFLUENCE_USER=your-email@yourorg.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token
CONFLUENCE_SPACE_KEYS=OPS,HR

# Jira (Atlassian Cloud)
JIRA_URL=https://yourorg.atlassian.net
JIRA_USER=your-email@yourorg.com
JIRA_API_TOKEN=your-atlassian-api-token
JIRA_PROJECT_KEYS=BANK,DEV

# Microsoft Graph (Outlook + SharePoint)
# Register an App in Azure AD with: Mail.Read, Sites.Read.All permissions
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-app-client-id
MS_CLIENT_SECRET=your-app-client-secret
MS_MAILBOX=mailbox@yourorg.com
MS_SHAREPOINT_SITE_ID=yourorg.sharepoint.com,site-guid,web-guid
MS_SHAREPOINT_DRIVE_ID=drive-guid

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Frequency for automatic live-connector sync (hours)
SYNC_INTERVAL_HOURS=6

# Optional: Slack Incoming Webhook URL for sync notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../X...
