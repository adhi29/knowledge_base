# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# Models (defaults shown)
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o
ROUTER_MODEL=gpt-4o-mini

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ── Storage ───────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
SQLITE_DB_PATH=data/chatbot.db

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Retrieval ──────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
BM25_WEIGHT=0.4
SEMANTIC_WEIGHT=0.6

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Enterprise Source Connectors (stub — fill when credentials available) ─────
# SharePoint
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=
# SHAREPOINT_SITE_ID=

# Confluence
# CONFLUENCE_URL=https://yourorg.atlassian.net
# CONFLUENCE_USER=your-email@yourorg.com
# CONFLUENCE_API_TOKEN=

# Jira
# JIRA_URL=https://yourorg.atlassian.net
# JIRA_USER=your-email@yourorg.com
# JIRA_API_TOKEN=

# Outlook / Exchange
# OUTLOOK_TENANT_ID=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
